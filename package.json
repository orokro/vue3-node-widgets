{
  "name": "vue3-node-widgets",
  "version": "0.0.1-beta.2",
  "description": "A Vue 3 component library for building node-graph editors. Ships a graph editor component, a type/coalescer system with multi-hop conversion, and a JSON AST output suitable for shader codegen.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/vue3-node-widgets.cjs",
  "module": "./dist/vue3-node-widgets.js",
  "exports": {
    ".": {
      "import": "./dist/vue3-node-widgets.js",
      "require": "./dist/vue3-node-widgets.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "vue": "^3.5.22",
    "material-design-icons-iconfont": "^6.7.0"
  },
  "peerDependenciesMeta": {
    "material-design-icons-iconfont": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "colord": "^2.9.3",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "gdraghelper": "^1.0.3",
    "material-design-icons-iconfont": "^6.7.0",
    "sass": "^1.93.2",
    "typical": "^7.3.0",
    "vite": "^6.0.5",
    "vite-plugin-vue-devtools": "^7.6.8",
    "vue": "^3",
    "vue-win-mgr": "^0.9.1"
  }
}
